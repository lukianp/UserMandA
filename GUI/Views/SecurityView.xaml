<UserControl x:Class="MandADiscoverySuite.Views.SecurityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Security Posture" FontSize="24" FontWeight="Bold" 
                       Foreground="{DynamicResource ForegroundBrush}"/>
            <TextBlock Text="Monitor MFA coverage, admin roles, risky users, and security vulnerabilities" 
                       FontSize="14" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- Security KPI Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" 
                    Padding="15" Margin="0,0,10,0" BorderBrush="#FF10B981" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="MFA Coverage" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MFAPercentage}" FontSize="24" FontWeight="Bold" Foreground="#FF10B981"/>
                        <TextBlock Text="%" FontSize="16" FontWeight="Bold" Foreground="#FF10B981" Margin="2,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding MFAUsersText}" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" 
                    Padding="15" Margin="5,0" BorderBrush="#FFFBBF24" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="Admin Accounts" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}"/>
                    <TextBlock Text="{Binding AdminAccountsCount}" FontSize="24" FontWeight="Bold" Foreground="#FFFBBF24"/>
                    <TextBlock Text="privileged users" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" 
                    Padding="15" Margin="5,0" BorderBrush="#FFEF4444" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="Risky Users" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}"/>
                    <TextBlock Text="{Binding RiskyUsersCount}" FontSize="24" FontWeight="Bold" Foreground="#FFEF4444"/>
                    <TextBlock Text="need attention" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="3" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" 
                    Padding="15" Margin="10,0,0,0" BorderBrush="#FF9B59B6" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="Security Score" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SecurityScore}" FontSize="24" FontWeight="Bold" Foreground="#FF9B59B6"/>
                        <TextBlock Text="/100" FontSize="16" FontWeight="Bold" Foreground="#FF9B59B6" Margin="2,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SecurityScoreText}" FontSize="10" Foreground="{DynamicResource MutedForegroundBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Security Issues Grid -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" 
                    Padding="20" Margin="0,0,10,0" BorderBrush="{DynamicResource MutedForegroundBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Security Issues" FontSize="16" FontWeight="SemiBold" 
                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10"/>
                    
                    <!-- Filter Bar -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <ComboBox Width="150" SelectedItem="{Binding SelectedSeverity}"
                                  ItemsSource="{Binding SeverityFilter}" Margin="0,0,10,0"/>
                        <ComboBox Width="150" SelectedItem="{Binding SelectedCategory}"
                                  ItemsSource="{Binding CategoryFilter}"/>
                        <Button Content="Refresh" Margin="15,0,0,0" Padding="15,5"
                                Command="{Binding RefreshCommand}"/>
                    </StackPanel>
                    
                    <!-- Loading/Content States -->
                    <Grid Grid.Row="2">
                        <!-- Loading State -->
                        <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="200" Height="6" Margin="0,0,0,10"/>
                            <TextBlock Text="Loading security data..." FontSize="14" 
                                       Foreground="{DynamicResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Security Issues List -->
                        <DataGrid ItemsSource="{Binding SecurityIssues}" SelectedItem="{Binding SelectedIssue}"
                                  Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  Background="{DynamicResource BackgroundBrush}"
                                  BorderBrush="{DynamicResource MutedForegroundBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="80"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                                <DataGridTextColumn Header="Issue" Binding="{Binding Title}" Width="*"/>
                                <DataGridTextColumn Header="Affected" Binding="{Binding AffectedCount}" Width="80"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        
                        <!-- No Data State -->
                        <StackPanel Visibility="{Binding HasNoData, Converter={StaticResource BoolToVisibilityConverter}}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🛡️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="No security issues found" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Run security discovery to populate data" FontSize="14"
                                       Foreground="{DynamicResource MutedForegroundBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Quick Actions Panel -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" 
                    Padding="20" BorderBrush="{DynamicResource MutedForegroundBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold" 
                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,15"/>
                    
                    <Button Content="View Security Groups" Margin="0,0,0,10" Padding="15,8"
                            Command="{Binding ViewSecurityGroupsCommand}"/>
                    <Button Content="View Group Policies" Margin="0,0,0,10" Padding="15,8"
                            Command="{Binding ViewGroupPoliciesCommand}"/>
                    <Button Content="Risky Users Analysis" Margin="0,0,0,10" Padding="15,8"
                            Command="{Binding ViewRiskyUsersCommand}"/>
                    <Button Content="MFA Report" Margin="0,0,0,10" Padding="15,8"
                            Command="{Binding ViewMFAReportCommand}"/>
                    <Button Content="Certificate Analysis" Margin="0,0,0,10" Padding="15,8"
                            Command="{Binding ViewCertificatesCommand}"/>
                    
                    <TextBlock Text="Security Recommendations" FontSize="14" FontWeight="SemiBold" 
                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,20,0,10"/>
                    
                    <ItemsControl ItemsSource="{Binding SecurityRecommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFF8F9FA" BorderBrush="{DynamicResource MutedForegroundBrush}" 
                                        BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>